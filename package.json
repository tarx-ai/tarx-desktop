{
  "name": "tarx-desktop",
  "version": "1.1.6",
  "description": "TARX Desktop — Local AI on your hardware",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "assets": "node scripts/build-assets.js",
    "prebuild": "npm run assets",
    "build": "electron-builder --mac",
    "dev": "NODE_ENV=development electron .",
    "local-data": "node scripts/local-data.js",
    "fresh-app-test": "node scripts/local-data.js fresh-app-test"
  },
  "author": "TARXAN INC.",
  "license": "UNLICENSED",
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.tarxan.tarx",
    "productName": "TARX",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "identity": "John Wantz (JH4243GARF)",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "TARX uses the microphone for voice input so you can speak instead of type."
      }
    },
    "afterSign": "./scripts/notarize.js",
    "dmg": {
      "title": "TARX",
      "background": "assets/dmg-background.png",
      "iconSize": 96,
      "window": {
        "width": 640,
        "height": 420
      },
      "contents": [
        {
          "x": 170,
          "y": 230,
          "type": "file"
        },
        {
          "x": 470,
          "y": 230,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "publish": {
      "provider": "generic",
      "url": "https://tarx.com/api/download/electron"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
