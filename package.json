{
  "name": "tarx-desktop",
  "version": "1.1.8",
  "description": "TARX Desktop — Local AI on your hardware",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "assets": "node scripts/build-assets.js",
    "prebuild": "npm run assets",
    "build": "electron-builder --mac",
    "dev": "NODE_ENV=development electron .",
    "local-data": "node scripts/local-data.js",
    "fresh-app-test": "node scripts/local-data.js fresh-app-test",
    "build:voice-beta": "electron-builder --mac --config build/electron-builder.voice-beta.yml",
    "qa:voice-beta-package-contract": "node scripts/qa-voice-beta-package-contract.js",
    "qa:native-voice-capture-contract": "node scripts/qa-native-voice-capture-contract.js",
    "qa:native-capture-adapter": "node scripts/qa-native-capture-adapter-availability.js",
    "qa:native-capture-stt-route": "node scripts/qa-native-capture-stt-route.js",
    "qa:voice-native-stt": "node scripts/qa-voice-native-stt.js",
    "qa:vision-freshness": "node scripts/qa-vision-freshness.js",
    "qa:action-safety-gate": "node scripts/qa-action-safety-gate.js",
    "qa:local-operator-control-plane": "node scripts/qa-local-operator-control-plane.js",
    "qa:local-operator-footprint": "node scripts/qa-local-operator-footprint.js",
    "qa:voice-pronunciation-rule": "node scripts/qa-voice-pronunciation-rule.js",
    "qa:voice-input-inventory": "node scripts/qa-voice-input-inventory.js",
    "qa:voice-input-doctor": "node scripts/qa-voice-input-doctor.js",
    "qa:voice-audio-diagnostics": "node scripts/qa-voice-audio-diagnostics.js",
    "qa:voice-internal-beta-loop": "node scripts/qa-voice-internal-beta-loop.js",
    "qa:voice-panel-state-machine": "node scripts/qa-voice-panel-state-machine.js",
    "qa:voice-evidence-panel": "node scripts/qa-voice-evidence-panel.js",
    "qa:voice-prime-readiness": "node scripts/qa-voice-prime-readiness.js"
  },
  "author": "TARXAN INC.",
  "license": "UNLICENSED",
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.tarxan.tarx",
    "productName": "TARX",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "identity": "John Wantz (JH4243GARF)",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "TARX uses the microphone for voice input so you can speak instead of type."
      }
    },
    "files": [
      "electron/**",
      "assets/**",
      "resources/local-operator-packs.json",
      "package.json",
      "node_modules/**",
      "!**/.tarx/**",
      "!**/runs/**",
      "!**/diagnostics/**",
      "!**/voice-captures/**",
      "!**/vision-observations/**",
      "!**/models/**",
      "!**/*.gguf",
      "!**/*.ggml",
      "!**/*.onnx",
      "!**/*.safetensors",
      "!**/*.pt",
      "!**/*.pth",
      "!**/*.ckpt",
      "!**/*.tflite",
      "!**/*.wav",
      "!**/*.webm",
      "!**/*.flac",
      "!**/*.mp3",
      "!**/*.jsonl"
    ],
    "afterSign": "./scripts/notarize.js",
    "dmg": {
      "title": "TARX",
      "background": "assets/dmg-background.png",
      "iconSize": 96,
      "window": {
        "width": 640,
        "height": 420
      },
      "contents": [
        {
          "x": 170,
          "y": 230,
          "type": "file"
        },
        {
          "x": 470,
          "y": 230,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "publish": {
      "provider": "generic",
      "url": "https://tarx.com/api/download/electron"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
