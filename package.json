{
  "name": "tarx-desktop",
  "version": "1.1.13",
  "description": "TARX Desktop — Local AI on your hardware",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "start:voice-internal": "bash scripts/start-voice-internal.sh",
    "assets": "node scripts/build-assets.js",
    "prebuild": "npm run assets",
    "build": "electron-builder --mac",
    "dev": "NODE_ENV=development electron .",
    "local-data": "node scripts/local-data.js",
    "fresh-app-test": "node scripts/local-data.js fresh-app-test",
    "build:voice-beta": "electron-builder --mac --config build/electron-builder.voice-beta.yml",
    "qa:voice-beta-package-contract": "node scripts/qa-voice-beta-package-contract.js",
    "qa:electron-native-packaging:test": "node --test scripts/qa-electron-native-packaging.test.js",
    "qa:native-voice-capture-contract": "node scripts/qa-native-voice-capture-contract.js",
    "qa:native-capture-adapter": "node scripts/qa-native-capture-adapter-availability.js",
    "qa:native-capture-stt-route": "node scripts/qa-native-capture-stt-route.js",
    "qa:voice-native-stt": "node scripts/qa-voice-native-stt.js",
    "qa:vision-freshness": "node scripts/qa-vision-freshness.js",
    "qa:action-safety-gate": "node scripts/qa-action-safety-gate.js",
    "qa:local-operator-control-plane": "node scripts/qa-local-operator-control-plane.js",
    "qa:local-operator-footprint": "node scripts/qa-local-operator-footprint.js",
    "qa:voice-pronunciation-rule": "node scripts/qa-voice-pronunciation-rule.js",
    "qa:voice-input-inventory": "node scripts/qa-voice-input-inventory.js",
    "qa:voice-input-doctor": "node scripts/qa-voice-input-doctor.js",
    "qa:voice-audio-diagnostics": "node scripts/qa-voice-audio-diagnostics.js",
    "qa:voice-live-calibration": "node scripts/qa-voice-live-calibration.js",
    "qa:voice-manual-loop": "node scripts/qa-voice-manual-loop.js",
    "qa:voice-manual-intelligence": "node scripts/qa-voice-manual-intelligence.js",
    "qa:voice-manual-electron-path": "node scripts/qa-voice-manual-electron-path.js",
    "qa:voice-mediadevices-spike": "node scripts/qa-voice-mediadevices-spike.js",
    "qa:voice-mediadevices-product-capture": "node scripts/qa-voice-mediadevices-product-capture.js",
    "qa:voice-device-manager": "node scripts/qa-voice-device-manager.js",
    "qa:voice-device-drift": "node scripts/qa-voice-device-drift.js",
    "voice:pipecat-spike": "node scripts/voice-pipecat-spike-service.js once",
    "qa:voice-pipecat-spike": "node scripts/qa-voice-pipecat-spike.js",
    "qa:voice-internal-beta-loop": "node scripts/qa-voice-internal-beta-loop.js",
    "qa:voice-tts-playback": "node scripts/qa-voice-tts-playback.js",
    "qa:voice-acoustic-loop": "node scripts/qa-voice-acoustic-loop.js",
    "qa:voice-panel-state-machine": "node scripts/qa-voice-panel-state-machine.js",
    "qa:voice-evidence-panel": "node scripts/qa-voice-evidence-panel.js",
    "qa:voice-prime-readiness": "node scripts/qa-voice-prime-readiness.js",
    "qa:runtime-spine-performance": "node scripts/qa-runtime-spine-performance.js",
    "qa:runtime-spine-readiness": "node scripts/qa-runtime-spine-readiness.js",
    "qa:electron-black-screen-recovery": "node scripts/qa-electron-black-screen-recovery.js",
    "qa:electron-native-packaging": "node scripts/qa-electron-native-packaging.js",
    "qa:electron-release-stability": "node scripts/qa-electron-release-stability.js",
    "qa:g3-daemon-first-funnel": "node scripts/qa-g3-daemon-first-funnel.js",
    "qa:electron-navigation-boundary": "node scripts/qa-electron-navigation-boundary.js"
  },
  "author": "TARXAN INC.",
  "license": "UNLICENSED",
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.tarxan.tarx",
    "productName": "TARX",
    "npmRebuild": false,
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
    "hardenedRuntime": true,
    "identity": "John Wantz (JH4243GARF)",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
      "NSMicrophoneUsageDescription": "TARX uses the microphone for voice input so you can speak instead of type."
    }
  },
  "asarUnpack": [
    "node_modules/better-sqlite3-multiple-ciphers/**",
    "node_modules/bindings/**",
    "node_modules/prebuild-install/**",
    "node_modules/base64-js/**",
    "node_modules/bl/**",
    "node_modules/buffer/**",
    "node_modules/chownr/**",
    "node_modules/decompress-response/**",
    "node_modules/deep-extend/**",
    "node_modules/detect-libc/**",
    "node_modules/end-of-stream/**",
    "node_modules/expand-template/**",
    "node_modules/file-uri-to-path/**",
    "node_modules/fs-constants/**",
    "node_modules/github-from-package/**",
    "node_modules/ieee754/**",
    "node_modules/inherits/**",
    "node_modules/ini/**",
    "node_modules/mimic-response/**",
    "node_modules/minimist/**",
    "node_modules/mkdirp-classic/**",
    "node_modules/napi-build-utils/**",
    "node_modules/node-abi/**",
    "node_modules/once/**",
    "node_modules/pump/**",
    "node_modules/rc/**",
    "node_modules/readable-stream/**",
    "node_modules/safe-buffer/**",
    "node_modules/semver/**",
    "node_modules/simple-concat/**",
    "node_modules/simple-get/**",
    "node_modules/string_decoder/**",
    "node_modules/strip-json-comments/**",
    "node_modules/tar-fs/**",
    "node_modules/tar-stream/**",
    "node_modules/tunnel-agent/**",
    "node_modules/util-deprecate/**",
    "node_modules/wrappy/**"
  ],
  "files": [
    "electron/**",
    "assets/**",
    "resources/bridge/**",
      "resources/local-operator-packs.json",
      "package.json",
      "node_modules/**",
      "!**/.tarx/**",
      "!**/runs/**",
      "!**/diagnostics/**",
      "!**/voice-captures/**",
      "!**/vision-observations/**",
      "!**/models/**",
      "!**/*.gguf",
      "!**/*.ggml",
      "!**/*.onnx",
      "!**/*.safetensors",
      "!**/*.pt",
      "!**/*.pth",
      "!**/*.ckpt",
      "!**/*.tflite",
      "!**/*.wav",
      "!**/*.webm",
      "!**/*.flac",
      "!**/*.mp3",
      "!**/*.jsonl"
    ],
    "afterSign": "./scripts/notarize.js",
    "dmg": {
      "title": "TARX",
      "background": "assets/dmg-background.png",
      "iconSize": 96,
      "window": {
        "width": 640,
        "height": 420
      },
      "contents": [
        {
          "x": 170,
          "y": 230,
          "type": "file"
        },
        {
          "x": 470,
          "y": 230,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "publish": {
      "provider": "generic",
      "url": "https://tarx.com/api/download/electron"
    }
  },
  "dependencies": {
    "better-sqlite3-multiple-ciphers": "^12.9.0",
    "electron-updater": "^6.8.3"
  }
}
